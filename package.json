{
  "name": "@johnkattenhorn/docmost-mcp",
  "version": "1.0.0",
  "description": "MCP server for Docmost - connects AI assistants to standard Docmost instances",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "docmost-mcp": "dist/bootstrap.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bootstrap.js",
    "dev": "tsx watch src/bootstrap.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "docmost",
    "claude",
    "ai",
    "model-context-protocol",
    "wiki",
    "documentation",
    "anthropic"
  ],
  "author": "John Kattenhorn <john@khn.family>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnkattenhorn/docmost-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/johnkattenhorn/docmost-mcp/issues"
  },
  "homepage": "https://github.com/johnkattenhorn/docmost-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.3",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@tiptap/core": "^3.13.0",
    "@tiptap/extension-link": "^3.13.0",
    "@tiptap/html": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@types/marked": "^6.0.0",
    "axios": "^1.7.9",
    "dotenv": "^16.5.0",
    "form-data": "^4.0.1",
    "marked": "^17.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
