# Docmost Server URL (your existing Docmost instance)
DOCMOST_URL=https://docs.khn.family

# ============================================
# AUTHENTIK PROXY AUTHENTICATION (if using Authentik)
# ============================================
# Create a token in Authentik: Directory > Tokens and App passwords
AUTHENTIK_USERNAME=your_authentik_username
AUTHENTIK_TOKEN=your_authentik_token

# ============================================
# DOCMOST DIRECT AUTHENTICATION (after Authentik)
# ============================================
# Option 1: Use the authToken cookie value from browser
# DOCMOST_AUTH_TOKEN=your_auth_token_from_cookie

# Option 2: Use email/password for automatic login
DOCMOST_EMAIL=your@email.com
DOCMOST_PASSWORD=your_password

# Debug mode (optional)
MCP_DEBUG=false
